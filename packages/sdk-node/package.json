{
  "name": "@agent-killswitch/sdk-node",
  "version": "0.4.0",
  "description": "Enterprise TypeScript SDK for Agent Kill Switch — resource-style API, resilient HTTP with hooks + logger, typed errors, HMAC request signing, idempotency keys, telemetry, agents, and kill APIs. Runs on Node 20+, Workers, Deno, Bun, Lambda.",
  "keywords": [
    "agent",
    "ai",
    "kill-switch",
    "governance",
    "telemetry",
    "policy",
    "sdk",
    "typescript",
    "fetch",
    "hmac",
    "idempotency",
    "observability",
    "opentelemetry",
    "enterprise"
  ],
  "license": "MIT",
  "homepage": "https://github.com/LoopVerses/Kill-Switch-SDK-Agent#readme",
  "bugs": {
    "url": "https://github.com/LoopVerses/Kill-Switch-SDK-Agent/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LoopVerses/Kill-Switch-SDK-Agent.git",
    "directory": "packages/sdk-node"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.10.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "node -e \"process.exit(0)\"",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test --test-timeout=15000 src/client.test.ts",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@agent-killswitch/shared-types": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
