{
  "name": "@agent-killswitch/sdk-node",
  "version": "0.3.2",
  "description": "Production TypeScript SDK for Agent Kill Switch: resource-style API, resilient HTTP, typed errors, telemetry, agents, and kill APIs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LoopVerses/Kill-Switch-SDK-Agent.git",
    "directory": "packages/sdk-node"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.10.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "lint": "node -e \"process.exit(0)\"",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/client.test.ts",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@agent-killswitch/shared-types": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
